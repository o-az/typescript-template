{
  "name": "typescript-template",
  "exports": "./index.js",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "nuke": "rimraf dist node_modules package-lock.json yarn.lock pnpm-lock.yaml bun.lockb",
    "compile": "cross-env-shell babel src -d dist --source-maps --extensions '.ts'",
    "start": "yarn node-options && node dist/src/index.js",
    "test": "yarn node-options && vitest",
    "test-file": "yarn node-options && vitest $npm_config_path",
    "lint": "npx eslint --fix ./src",
    "format": "npx prettier --write ./src",
    "typecheck": "tsc -p .",
    "build": "yarn clean && tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "tsnode": "node --experimental-specifier-resolution=node --loader ts-node/esm $npm_config_path",
    "node-options": "NODE_OPTIONS=\"--experimental-fetch --no-warnings --experimental-specifier-resolution=node\""
  },
  "devDependencies": {
    "@swc/core": "^1.2.210",
    "@types/babel-core": "^6.25.7",
    "@types/dom-screen-wake-lock": "^1.0.0",
    "@types/eslint": "^8.4.5",
    "@types/node": "^18.0.3",
    "@types/prettier": "^2.6.3",
    "@typescript-eslint/eslint-plugin": "^5.30.5",
    "@typescript-eslint/parser": "^5.30.5",
    "bun-types": "^0.0.83",
    "dotenv": "^16.0.1",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "prettier": "^2.7.1",
    "rimraf": "^3.0.2",
    "ts-node": "^10.8.2",
    "tsc-alias": "^1.6.11",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^4.7.4",
    "vite-tsconfig-paths": "^3.5.0",
    "vitest": "^0.17.0"
  },
  "engines": {
    "npm": ">=7.0.0",
    "node": ">=17.0.0",
    "yarn": ">=1.22.0"
  },
  "engineStrict": true,
  "version": "1.0.0",
  "description": "TypeScript template I use. TypeScript/ESLint/Prettier/dotenv/vitest",
  "author": "o-az",
  "license": "GPL-3.0-or-later"
}