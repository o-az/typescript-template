{
  "name": "typescript-template",
  "scripts": {
    "start": "yarn node-options & node dist/index.js",
    "test": "yarn node-options && vitest",
    "test-file": "yarn node-options && vitest $npm_config_path",
    "lint": "npx eslint --fix ./src",
    "format": "npx prettier --write .",
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "tsnode": "yarn node-options && ts-node --skip-project -T -r tsconfig-paths/register $npm_config_path",
    "node-options": "NODE_OPTIONS=\"--experimental-fetch --no-warnings\""
  },
  "devDependencies": {
    "@types/eslint": "^8.4.2",
    "@types/node": "^17.0.31",
    "@types/prettier": "^2.6.0",
    "@typescript-eslint/eslint-plugin": "^5.22.0",
    "@typescript-eslint/parser": "^5.22.0",
    "dotenv": "^16.0.0",
    "eslint": "^8.15.0",
    "eslint-config-prettier": "^8.5.0",
    "prettier": "^2.6.2",
    "ts-node": "^10.7.0",
    "tsc-alias": "^1.6.7",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^4.6.4",
    "vitest": "^0.10.5"
  },
  "engines": {
    "npm": ">=7.0.0",
    "node": ">=17.0.0",
    "yarn": ">=1.22.0"
  },
  "engineStrict": true,
  "version": "1.0.0",
  "description": "TypeScript template I use. TypeScript/ESLint/Prettier/dotenv/vitest",
  "main": "index.js",
  "author": "o-az",
  "license": "GPL-3.0-or-later"
}
